# Mini CPO Platform - local defaults mirror docker-compose.yml.

HTTP_ADDR=:8080
DATABASE_URL=postgres://cpo:cpo@db:5432/cpo?sslmode=disable
MQTT_BROKER=tcp://mosquitto:1883
MQTT_CLIENT_ID=cpo-backend
PRICE_PER_KWH=8.50
PEAK_PRICE_PER_KWH=8.50
OFFPEAK_PRICE_PER_KWH=7.20
DC_POWER_THRESHOLD_KW=50
DC_PRICE_MULTIPLIER=1.15
PEAK_START_HOUR=7
PEAK_END_HOUR=21
OFFLINE_AFTER_SECONDS=90
CORS_ALLOWED_ORIGINS=*

# Per-station simulator variables are set on each compose service.
# STATION_ID=station-1
# MAX_POWER_KW=22
# FAULT_PROBABILITY=0.01
